generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                       String   @id @default(cuid())
  email                    String   @unique
  passwordHash             String
  firstName                String
  lastName                 String
  gender                   String?  // male | female | other | prefer_not_to_say
  birthday                 String?
  countryOfResidenceCode   String?
  countryOfResidenceName   String?
  emailVerified            Boolean  @default(false)
  lastLoginAt              DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  citizenships UserCitizenship[]
  visas        UserVisa[]
  otps         OTP[]
}

model UserCitizenship {
  id             String  @id @default(cuid())
  userId         String
  countryCode    String
  countryName    String
  documentNumber String?
  isPrimary      Boolean @default(false)

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  visas UserVisa[]
}

model UserVisa {
  id             String  @id @default(cuid())
  userId         String
  citizenshipId  String
  countryCode    String
  countryName    String
  visaType       String?
  documentNumber String?
  validUntil     String?

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  citizenship UserCitizenship @relation(fields: [citizenshipId], references: [id], onDelete: Cascade)
}

model OTP {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ───────────────────────────────────────────────────────────────────────────────
// When To Go — per-day cheapest fare cache keyed on (origin, destination, date).
// `cheapestUsd` is nullable on purpose: a row with NULL means we already checked
// this day and Kiwi returned no priced itineraries, so we should NOT refetch it
// before ttlUntil. That's the difference between "we've never sampled this day"
// (no row exists) and "we sampled it, no flights" (row exists, price = NULL).
//
// PK is (origin, destination, date) so upserts are idempotent and the table can
// be scanned cheaply by an index lookup on (origin, destination).
// ───────────────────────────────────────────────────────────────────────────────
model PriceCalendarDay {
  origin       String
  destination  String
  date         String   // YYYY-MM-DD departure date
  cheapestUsd  Float?   // null = checked, no priced itineraries for this day
  currency     String   @default("USD")
  bookingUrl   String?
  source       String   // 'kiwi-range' for v1
  sampledAt    DateTime @default(now())
  ttlUntil     DateTime

  @@id([origin, destination, date])
  @@index([origin, destination])
}
