PORT=4100
NODE_ENV=development

# Origin allowed by CORS. Use a comma-separated list for multiple origins,
# or "*" to allow all (not recommended in production).
ALLOWED_ORIGIN=http://localhost:5173

# When true, the service refreshes the in-memory dataset once every 24h.
AUTO_REFRESH=false

# Optional bearer token required to call POST /refresh.
# In production NODE_ENV=production this MUST be set, otherwise /refresh returns 503.
REFRESH_TOKEN=

# Raw URL of passport-index.json. Override only if you fork the dataset.
PASSPORT_INDEX_URL=https://raw.githubusercontent.com/imorte/passport-index-data/master/passport-index.json
