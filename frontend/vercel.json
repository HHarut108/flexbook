{
  "installCommand": "cd .. && npm install",
  "buildCommand": "cd .. && npm run build --workspace=packages/shared && npm run build --workspace=frontend",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/trip-builder", "destination": "/hop-planner", "permanent": true },
    { "source": "/budget-planner", "destination": "/trip-planner", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!api|icons|assets|sw\\.js|workbox-.*\\.js|manifest\\.webmanifest).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "//": "Hashed Vite assets — content-addressed, so the cache can live forever. immutable tells the browser not to revalidate even on reload.",
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "//": "App icons rarely change; long cache + must-revalidate keeps the manifest honest if we ever swap them.",
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
    }
  ]
}
